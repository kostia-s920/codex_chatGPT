{
  "name": "threads-telegram-agent",
  "version": "1.0.0",
  "description": "Autonomous AI agent that monitors Threads and sends curated insights to Telegram",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts cron",
    "cron": "tsx src/index.ts cron",
    "run-once": "tsx src/index.ts run-once",
    "scrape-only": "tsx src/index.ts scrape-only",
    "test-telegram": "tsx src/index.ts test-telegram",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js cron",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "node-cron": "^4.2.1",
    "openai": "^4.104.0",
    "playwright": "^1.53.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
